backend/.venv*/
*.pyc

# Local TTS voice samples (regenerate with the Kokoro verify script)
backend/tts_samples/

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/next-env.d.ts

# Env / secrets
.env
.env.local
backend/.env
frontend/.env.local
# per-account Google OAuth tokens (created at runtime by the connect flow)
backend/tokens/
# persisted conversation history (last-20 per channel; contains message content)
backend/.zenith/
# local Markdown memory vault (personal notes + client data — never commit; M6)
backend/vault/

# OS
.DS_Store

# Build / tool caches (regenerable)
*.tsbuildinfo
.impeccable/

# graphify knowledge graph output (regenerate with /graphify)
graphify-out/

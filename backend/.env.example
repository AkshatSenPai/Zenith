# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Speech-to-text model. small/cpu/int8 is the offline default, but it MISHEARS real Hinglish.
# For real accuracy on the 32GB GPU desktop (recommended), set all three:
#   WHISPER_MODEL=large-v3, WHISPER_DEVICE=cuda, WHISPER_COMPUTE=float16
# (auto-falls back to CPU if CUDA/cuDNN isn't available, so it can't brick startup).
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
# Transcript language: unset = auto-detect (English→English, Hindi→romanised to Latin).
# Force "en" (English only) or "hi" (Hindi only) if auto-detect misbehaves.
# WHISPER_LANGUAGE=

# Text-to-speech voice (edge-tts neural, free, needs internet). Other picks:
# hi-IN-SwaraNeural, en-IN-PrabhatNeural, hi-IN-MadhurNeural
ZENITH_TTS_VOICE=en-IN-NeerjaNeural

# --- Text-to-speech engine ----------------------------------------------------
# "edge" (default, cloud Microsoft neural voices, MP3) or "kokoro" (local/offline, WAV).
ZENITH_TTS_ENGINE=edge
# Kokoro voice (used when ZENITH_TTS_ENGINE=kokoro). Grade-A: af_heart (US female),
# am_michael (US male). British / JARVIS-like: bm_george. (ZENITH_TTS_VOICE above stays
# the edge-tts voice, used when ZENITH_TTS_ENGINE=edge.)
ZENITH_KOKORO_VOICE=af_heart
ZENITH_KOKORO_LANG=a        # a = American English, b = British English
ZENITH_KOKORO_DEVICE=cpu    # cpu (default, plenty fast for an 82M model) or cuda

# Backend API token: shared secret required in the X-Zenith-Token header on all routes
# except GET / and GET /health. Blank = disabled (localhost-only). Generate any random string.
ZENITH_API_TOKEN=

# Verbose tool-call logging (full inputs + results). Blank/0 = log only tool name + ok/failed.
ZENITH_DEBUG_LOGS=

# Morning-briefing news (free RSS, no key). Optional: override the default world+India feeds.
# Comma-separated "Label|url" pairs. Leave blank to use the BBC World + Times of India defaults.
NEWS_FEEDS=

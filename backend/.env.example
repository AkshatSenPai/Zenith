# Zenith backend configuration â€” copy to .env (gitignored) and fill in your values.
# .env holds real secrets; this .example file must NEVER contain them.

# â”€â”€ Core: Claude (REQUIRED) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Anthropic API key â€” get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# â”€â”€ Security: backend API token â€” see SECURITY.md â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Shared secret required as the X-Zenith-Token header on every route. Leave blank for
# localhost-only dev (fail-open + a loud startup warning); set it to enforce auth (401 without).
# MUST equal the frontend's NEXT_PUBLIC_ZENITH_API_TOKEN. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ZENITH_API_TOKEN=

# â”€â”€ Google: Calendar + Gmail (optional) â€” see SETUP-GOOGLE.md â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# â”€â”€ Weather: "good morning" briefing (optional) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# OpenWeatherMap API key + a default city (e.g. Mumbai,IN) for the spoken briefing.
WEATHER_API_KEY=
WEATHER_DEFAULT_LOCATION=

# â”€â”€ Discord: server-channel tools (optional) â€” see SETUP-DISCORD.md â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Bot token; requires the Message Content intent. Server channels only, never DMs.
DISCORD_BOT_TOKEN=

# â”€â”€ Telegram: phone remote into the SAME brain (optional) â€” see SETUP-TELEGRAM.md
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Allow-list of numeric Telegram user IDs (comma- or semicolon-separated). REQUIRED â€” an
# empty list rejects everyone (fail-closed). Message @userinfobot to find your id.
TELEGRAM_ALLOWED_USER_IDS=

# â”€â”€ Voice out (TTS) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Engine: kokoro = local/offline (default; needs the Python 3.11 venv + its deps);
#         edge   = Microsoft neural over the internet (no extra deps â€” the zero-setup fallback).
ZENITH_TTS_ENGINE=kokoro
# edge-tts voice (used when ENGINE=edge).
ZENITH_TTS_VOICE=en-IN-NeerjaNeural
# Kokoro voice (used when ENGINE=kokoro): af_heart (US f), am_michael (US m), bm_george (UK).
ZENITH_KOKORO_VOICE=af_heart
# Kokoro language: a=American English, b=British English.
ZENITH_KOKORO_LANG=a
# Kokoro device: cpu (default) or cuda (needs a CUDA-matched torch â€” ~0.7s/paragraph vs ~17s).
ZENITH_KOKORO_DEVICE=cpu

# â”€â”€ Voice in (STT: faster-whisper) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Model: small (safe CPU default) / medium / large-v3 (best accuracy, needs a strong GPU).
WHISPER_MODEL=small
# Device: cpu (default) or cuda.
WHISPER_DEVICE=cpu
# Compute: int8 (CPU) / float16 (GPU).
WHISPER_COMPUTE=int8
# Language: en (default, fastest â€” no transliteration). Blank = auto-detect (dormant Hinglish
# path); hi = Hindi.
WHISPER_LANGUAGE=en

# â”€â”€ Logging â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# 1/true/yes/on = log full tool inputs + results (incl. message bodies) while debugging.
# Default (unset) logs only the tool name + outcome â€” never bodies / recipients / email text.
ZENITH_DEBUG_LOGS=

# â”€â”€ News: morning-briefing headlines (optional) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Comma-separated 'Label|RSS-url' feeds. Defaults to world (BBC) + India (Times of India).
NEWS_FEEDS=

# â”€â”€ Memory vault: local Markdown notes (optional) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Directory for Zenith's note vault (daily logs, client briefs, notes). Defaults to
# backend/vault. Point it at an existing Obsidian vault to share notes, e.g.
#   ZENITH_VAULT_PATH=C:\Users\Akshat Singh\ZenithVault
ZENITH_VAULT_PATH=
# Notion - internal integration (notion.so/my-integrations). SHARE pages/DBs WITH the integration
# inside Notion (page -> ... -> Connections), or Zenith sees nothing. See SETUP-NOTION.md.
NOTION_API_KEY=
NOTION_VERSION=2022-06-28

# -- Rate limit / daily token kill-switch --------------------------------------
# Hard daily token ceiling (input+output) before Zenith stops answering for the day.
# Defaults to 500000. Raise/lower to tune cost vs. headroom without a code change.
ZENITH_DAILY_TOKEN_BUDGET=500000

# -- App Launcher --------------------------------------------------------------
# Optional path to your app whitelist. Defaults to backend/apps.json
# (falls back to backend/apps.example.json). Whitelist only - never runs arbitrary commands.
ZENITH_APPS_PATH=
